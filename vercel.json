{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/ai/*.js": {
      "includeFiles": "public/questions.js",
      "maxDuration": 30
    }
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-store"
        },
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
