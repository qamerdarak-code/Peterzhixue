{
  "project": "皮特智学",
  "version": "0.2.0",
  "subjects": [
    "medical-psychology",
    "medical-statistics",
    "medical-parasitology",
    "xigai",
    "pathology",
    "pathology-slides",
    "medical-microbiology"
  ],
  "endpoints": [
    {
      "method": "POST",
      "path": "/api/ai/explain",
      "request": {
        "questionId": "string, required",
        "regenerate": "boolean, optional"
      },
      "response": {
        "requestId": "string",
        "cached": "boolean",
        "explanation": {
          "officialAnswer": "string",
          "conclusion": "string",
          "coreReasoning": ["string"],
          "optionAnalysis": [
            {
              "option": "string",
              "judgment": "正确 | 错误 | 有争议",
              "explanation": "string"
            }
          ],
          "knowledgePoints": ["string"],
          "commonMistake": "string",
          "mnemonic": "string",
          "confidence": "number, 0 to 1",
          "needsReview": "boolean",
          "reviewReason": "string"
        }
      }
    },
    {
      "method": "POST",
      "path": "/api/ai/explanation-feedback",
      "request": {
        "questionId": "string, required",
        "type": "like | dislike | incorrect | unclear | other"
      },
      "response": {
        "success": "boolean",
        "questionId": "string",
        "type": "string",
        "count": "number"
      }
    }
  ],
  "security": {
    "questionSource": "server-side lookup by questionId",
    "secretStorage": "server environment only",
    "ipRateLimit": "5 generated explanations per minute",
    "userRateLimit": "20 generated explanations per day",
    "cacheHitsConsumeQuota": false
  }
}
